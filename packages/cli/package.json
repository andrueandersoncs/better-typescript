{
  "name": "@better-typescript/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "better-typescript": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts --pretty",
    "start": "tsx src/index.ts",
    "watch": "tsx src/index.ts --pretty --watch",
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@better-typescript/checks": "0.0.0",
    "@better-typescript/core": "0.0.0",
    "@effect/platform-node": "^4.0.0-beta.98",
    "effect": "^4.0.0-beta.98"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
