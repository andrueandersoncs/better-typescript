{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@better-typescript/core/engine/check": ["../../packages/core/src/engine/check.ts"],
      "@better-typescript/core/engine/location": ["../../packages/core/src/engine/location.ts"],
      "@better-typescript/core/engine/derive": ["../../packages/core/src/engine/derive.ts"],
      "@better-typescript/core/engine/example": ["../../packages/core/src/engine/example.ts"],
      "@better-typescript/core/engine/report": ["../../packages/core/src/engine/report.ts"],
      "@better-typescript/core/engine/watch": ["../../packages/core/src/engine/watch.ts"],
      "@better-typescript/core/engine/sources": ["../../packages/core/src/engine/sources.ts"],
      "@better-typescript/checks/preset": ["../../packages/checks/src/preset.ts"],
      "@better-typescript/checks/preset/defaultWiring": ["../../packages/checks/src/preset/defaultWiring.ts"]
    }
  },
  "include": ["better-typescript.config.ts"]
}
